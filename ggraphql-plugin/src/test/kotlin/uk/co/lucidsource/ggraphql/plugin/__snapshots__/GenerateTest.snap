uk.co.lucidsource.ggraphql.plugin.GenerateTest.testGenerateWithCustomDirectiveAnnotations[annotation-schema.graphql]=[
"This directive allows results to be deferred during execution"
directive @defer(
    "Deferred behaviour is controlled by this argument"
    if: Boolean! = true,
    "A unique label that represents the fragment being deferred"
    label: String
  ) on FRAGMENT_SPREAD | INLINE_FRAGMENT

"Marks the field, argument, input field or enum value as deprecated"
directive @deprecated(
    "The reason for the deprecation"
    reason: String! = "No longer supported"
  ) on FIELD_DEFINITION | ARGUMENT_DEFINITION | ENUM_VALUE | INPUT_FIELD_DEFINITION

"""
 Test schema for custom directive annotation support
 This schema exercises various directive combinations to test annotation generation
 Custom directive definitions
"""
directive @entity on OBJECT | INTERFACE

"This directive disables error propagation when a non nullable field returns null for the given operation."
directive @experimental_disableErrorPropagation on QUERY | MUTATION | SUBSCRIPTION

"Directs the executor to include this field or fragment only when the `if` argument is true"
directive @include(
    "Included when true."
    if: Boolean!
  ) on FIELD | FRAGMENT_SPREAD | INLINE_FRAGMENT

"Indicates an Input Object is a OneOf Input Object."
directive @oneOf on INPUT_OBJECT

"Directs the executor to skip this field or fragment when the `if` argument is true."
directive @skip(
    "Skipped when true."
    if: Boolean!
  ) on FIELD | FRAGMENT_SPREAD | INLINE_FRAGMENT

"Exposes a URL that specifies the behaviour of this scalar."
directive @specifiedBy(
    "The URL that specifies the behaviour of this scalar."
    url: String!
  ) on SCALAR

directive @table(name: String!) on OBJECT | INTERFACE

directive @transactional on FIELD_DEFINITION

directive @validated on FIELD_DEFINITION | INPUT_OBJECT

" Interface type with custom directives (marker annotation)"
interface BaseEntity @entity {
  createdAt: DateTime
  id: ID!
}

" Object type with only parameterized directive"
type Category @table(name : "categories") {
  description: String
  id: ID!
  name: String!
  " Resolver field with custom directive only"
  products: [Product!]! @transactional
}

" Mutation type to test more resolver combinations"
type Mutation {
  deleteProduct(id: ID!): Boolean @transactional
  updateProduct(id: ID!, input: UpdateProductInput!): Product @transactional
}

" Object type with multiple custom directives (marker + parameterized)"
type Product implements BaseEntity @entity @table(name : "products") {
  createdAt: DateTime
  id: ID!
  name: String!
  price: Float!
  " Resolver field with both @resolver and custom directive"
  profile: ProductProfile @transactional
}

" Object type without custom directives (for comparison)"
type ProductProfile {
  description: String
  id: ID!
  tags: [String!]!
}

" Query type with resolver methods having custom directives"
type Query {
  " Regular resolver without custom directives"
  categories: [Category!]!
  " Resolver field with validated input"
  createProduct(input: CreateProductInput!): Product @transactional
  " Resolver field with custom directive"
  productById(id: ID!): Product @transactional
  " Regular field without custom directives"
  products: [Product!]!
}

scalar DateTime

" Input type with custom directive"
input CreateProductInput @validated {
  categoryId: ID!
  name: String!
  price: Float!
}

" Input type without custom directives (for comparison)"
input UpdateProductInput {
  name: String
  price: Float
}

]


